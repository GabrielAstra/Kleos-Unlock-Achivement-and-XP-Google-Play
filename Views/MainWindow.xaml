<Window x:Class="Kleos.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kleos" Height="760" Width="1240"
        MinHeight="620" MinWidth="960"
        Icon="/KleosIcon.ico"
        Background="#0d1117" Foreground="#e6edf3">

    <Window.Resources>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
        </Style>

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="#e6edf3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1a73e8"/>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#8b949e"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#3d1a1a"/>
            <Setter Property="Foreground" Value="#f85149"/>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#1a3d2b"/>
            <Setter Property="Foreground" Value="#3fb950"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#161b22"/>
            <Setter Property="Foreground" Value="#e6edf3"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#1a73e8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            
            <RowDefinition Height="*"/>
            
            <RowDefinition Height="36"/>
            
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/KleosIcon.ico" Width="32" Height="32" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Kleos" FontSize="18" FontWeight="Bold" Foreground="#e6edf3" VerticalAlignment="Center"/>
                    <TextBlock Text="Achievement Unlocker" FontSize="13" Foreground="#8b949e" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                
                <Border Grid.Column="1" Background="#0d1117" CornerRadius="6" Margin="20,10" Padding="10,0">
                    <TextBlock Text="{Binding DbPath, Mode=OneWay}" Foreground="#8b949e" FontSize="11"
                               FontFamily="Consolas" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </Border>

                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                    <Button Content="&#x2B07;  Pull from Device" Style="{StaticResource BtnPrimary}"
                            Click="BtnPullFromDevice_Click" Margin="0,0,8,0" Padding="14,7"/>
                    <Button Content="&#x1F4C2;  Open .db File" Style="{StaticResource BtnSecondary}"
                            Click="BtnOpenDb_Click" Margin="0,0,8,0" Padding="14,7"/>
                    <Button Content="&#x21BA;" Style="{StaticResource BtnSecondary}"
                            Click="BtnReload_Click" Padding="12,7" ToolTip="Reload database"/>
                </StackPanel>
            </Grid>
        </Border>

        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                
                <ColumnDefinition Width="*"/>
                
                <ColumnDefinition Width="280"/>
                
            </Grid.ColumnDefinitions>

            
            <Border Grid.Column="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <Grid Margin="12,16,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="130"/>
                    </Grid.RowDefinitions>

                    
                    <TextBlock Grid.Row="0" Text="GAMES" Style="{StaticResource SectionLabel}"/>

                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="LstGames"
                                 ItemsSource="{Binding Games}"
                                 SelectedItem="{Binding SelectedGame}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="GameCard" Background="#1c2128" CornerRadius="8"
                                            Padding="10,8" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#1a3a5c"/>
                                                        <Setter Property="BorderBrush" Value="#1a73e8"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False">
                                                        <Setter Property="BorderBrush" Value="#30363d"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="#e6edf3"
                                                       FontSize="13" FontWeight="Medium" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DeveloperName}" Foreground="#8b949e"
                                                       FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    
                    <TextBlock Grid.Row="2" Text="PLAYERS" Style="{StaticResource SectionLabel}" Margin="0,14,0,8"/>

                    
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding Players}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1c2128" CornerRadius="8" Padding="10,8"
                                            BorderBrush="#30363d" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" CornerRadius="14" Background="#1a73e8" Margin="0,0,8,0">
                                                <TextBlock Text="&#x1F464;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding ProfileName}" Foreground="#e6edf3"
                                                       FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            
            <Grid Grid.Column="1" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    
                    <RowDefinition Height="*"/>
                    
                    <RowDefinition Height="Auto"/>
                    
                </Grid.RowDefinitions>

                
                <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="TxtSearch"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="36,8,10,8"/>
                            <TextBlock Text="&#x1F50D;" FontSize="14" Foreground="#8b949e"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       IsHitTestVisible="False"/>
                            <TextBlock Text="Search achievements by name, description or ID..."
                                       Foreground="#484f58" FontSize="13" VerticalAlignment="Center"
                                       Margin="36,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <TextBlock Grid.Column="1" Foreground="#8b949e" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Run Text="{Binding Achievements.Count, Mode=OneWay}"/>
                            <Run Text=" achievements"/>
                        </TextBlock>
                    </Grid>
                </Border>

                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12,16,0">
                    <ListBox x:Name="LstAchievements"
                             ItemsSource="{Binding Achievements}"
                             SelectedItem="{Binding SelectedAchievement}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="AchCard" CornerRadius="10" Padding="14,12"
                                        Margin="0,0,0,8" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#161b22"/>
                                            <Setter Property="BorderBrush" Value="#30363d"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#1a3a5c"/>
                                                    <Setter Property="BorderBrush" Value="#1a73e8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#1a3d2b"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsIncremental}" Value="True">
                                                            <Setter Property="Background" Value="#1a2d4a"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSecret}" Value="True">
                                                            <Setter Property="Background" Value="#2d1a3d"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x1F3C6;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIncremental}" Value="True">
                                                                <Setter Property="Text" Value="&#x1F4CA;"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSecret}" Value="True">
                                                                <Setter Property="Text" Value="&#x1F512;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        
                                        <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="{Binding Name}" Foreground="#e6edf3"
                                                           FontSize="14" FontWeight="SemiBold"/>
                                                
                                                <Border CornerRadius="4" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Background" Value="#1a2d4a"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsIncremental}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="INCREMENTAL" Foreground="#58a6ff" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                
                                                <Border CornerRadius="4" Padding="5,1" Margin="4,0,0,0" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Background" Value="#2d1a3d"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSecret}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="SECRET" Foreground="#bc8cff" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" Foreground="#8b949e"
                                                       FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding ExternalAchievementId}" Foreground="#484f58"
                                                       FontSize="10" FontFamily="Consolas"/>
                                        </StackPanel>

                                        
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <Border Background="#1a3d2b" CornerRadius="12" Padding="8,3" HorizontalAlignment="Right" Margin="0,0,0,4">
                                                <TextBlock Foreground="#3fb950" FontSize="11" FontWeight="Bold">
                                                    <Run Text="{Binding DefinitionXpValue, Mode=OneWay}"/>
                                                    <Run Text=" XP"/>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="#8b949e">
                                                <Run Text="{Binding RarityPercent, StringFormat={}{0:F1}, Mode=OneWay}"/>
                                                <Run Text="% earned"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                
                <Border Grid.Row="2" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="&#x1F513;  Unlock Selected" Style="{StaticResource BtnPrimary}"
                                Click="BtnUnlockSelected_Click" Margin="0,0,8,0"/>
                        <Button Content="&#x1F513;  Unlock All" Style="{StaticResource BtnSuccess}"
                                Click="BtnUnlockAll_Click" Margin="0,0,8,0"/>
                        <Button Content="&#x1F194;  Unlock by ID..." Style="{StaticResource BtnSecondary}"
                                Click="BtnUnlockById_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            
            <Border Grid.Column="2" Background="#161b22" BorderBrush="#30363d" BorderThickness="1,0,0,0">
                <Grid Margin="14,16,14,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PENDING SYNC" Style="{StaticResource SectionLabel}" Margin="0"/>
                        <Border Grid.Column="1" Background="#1a3d2b" CornerRadius="10" Padding="7,2">
                            <TextBlock Foreground="#3fb950" FontSize="11" FontWeight="Bold"
                                       Text="{Binding PendingOps.Count, Mode=OneWay}"/>
                        </Border>
                    </Grid>

                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding PendingOps}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1c2128" CornerRadius="8" Padding="10,8"
                                            BorderBrush="#30363d" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                    Background="#3fb950" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding ExternalAchievementId}"
                                                           FontFamily="Consolas" FontSize="11" Foreground="#58a6ff"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding ExternalGameId}"
                                                           Foreground="#484f58" FontSize="10" FontFamily="Consolas"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    
                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <Button Content="Remove Duplicates" Style="{StaticResource BtnSecondary}"
                                Click="BtnRemoveDuplicates_Click" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                        <Button Content="&#x1F5D1;  Clear All" Style="{StaticResource BtnDanger}"
                                Click="BtnClearOps_Click" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    
                    <Border Grid.Row="3" Background="#0d1117" CornerRadius="10" Padding="12,10" Margin="0,14,0,0"
                            BorderBrush="#30363d" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="DEVICE SYNC" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                            <Button Content="&#x2B06;  Push .db to Device" Style="{StaticResource BtnPrimary}"
                                    Click="BtnPushDb_Click" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        
        <Border Grid.Row="2" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Width="7" Height="7" Fill="#3fb950" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="#8b949e"
                           FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</Window>
